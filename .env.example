# ============================================================
#  Environment Variables Template
#  สำหรับ GitHub Actions: ตั้งค่าใน repo Settings > Secrets and variables > Actions
#
#  ** Secrets (sensitive) ** - ใส่ใน "Secrets"
#    - TELEGRAM_BOT_TOKEN
#    - TELEGRAM_CHAT_ID
#    - LINE_NOTIFY_TOKEN
#
#  ** Variables (non-sensitive) ** - ใส่ใน "Variables"
#    - EXCHANGE, SYMBOL, TIMEFRAME, TIMEFRAME_MINUTES, OHLCV_LIMIT
#    - NOTIFY_CHANNEL, TZ_OFFSET_HOURS
# ============================================================

# --- Exchange (Variables) ---
EXCHANGE=bybit
SYMBOL=BTCUSDT
TIMEFRAME=15
TIMEFRAME_MINUTES=15
OHLCV_LIMIT=250

# --- Notification Channel (Variables) ---
# 'telegram' (default) | 'line' | 'both'
NOTIFY_CHANNEL=telegram

# --- Telegram (Secrets) ---
# สร้าง bot ผ่าน @BotFather แล้วนำ token มาใส่
TELEGRAM_BOT_TOKEN=
# นำ chat ID ของคุณ (หรือ group) มาใส่ - ดูได้จาก @userinfobot
TELEGRAM_CHAT_ID=

# --- LINE Notify (Secrets) ---
# ขอ token ได้ที่ https://notify-bot.line.me/
LINE_NOTIFY_TOKEN=

# --- Misc (Variables) ---
# 'true' = ทดสอบโดยไม่ส่งแจ้งเตือนจริง (พิมพ์ข้อความออก log)
DRY_RUN=false
# offset เวลาที่ต้องการแสดงในข้อความ (ชม.) - default 7 = Asia/Bangkok
TZ_OFFSET_HOURS=7
