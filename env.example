# ============================================================
#  Environment Variables Template
#  คัดลอกไฟล์นี้เป็น .env หรือตั้งค่าใน Vercel Dashboard
#  (Settings > Environment Variables)
# ============================================================

# --- Exchange ---
EXCHANGE=bybit
SYMBOL=BTCUSDT
TIMEFRAME=15
TIMEFRAME_MINUTES=15
OHLCV_LIMIT=250

# --- Notification Channel ---
# 'telegram' (default) | 'line' | 'both'
NOTIFY_CHANNEL=telegram

# --- Telegram (ถ้าใช้ channel=telegram หรือ both) ---
# สร้าง bot ผ่าน @BotFather แล้วนำ token มาใส่
TELEGRAM_BOT_TOKEN=
# นำ chat ID ของคุณ (หรือ group) มาใส่ - ดูได้จาก @userinfobot
TELEGRAM_CHAT_ID=

# --- LINE Notify (ถ้าใช้ channel=line หรือ both) ---
# ขอ token ได้ที่ https://notify-bot.line.me/
LINE_NOTIFY_TOKEN=

# --- Misc ---
# 'true' = ทดสอบโดยไม่ส่งแจ้งเตือนจริง (พิมพ์ข้อความออก console)
DRY_RUN=false
# ระบุ offset เวลาที่ต้องการแสดงในข้อความ (ชม.) - default 7 = Asia/Bangkok
TZ_OFFSET_HOURS=7
